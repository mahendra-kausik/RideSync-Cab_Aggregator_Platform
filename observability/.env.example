# Copy to observability/.env (git-ignored) and fill in real values from
# Grafana Cloud → your stack → Connections → Prometheus → "Hosted Prometheus metrics".

# Hostname only, no scheme (e.g. ridesync-cab-aggregator-platform.onrender.com)
RENDER_METRICS_HOST=

# The Remote Write Endpoint URL shown on that page (ends in /api/prom/push)
GRAFANA_CLOUD_PROMETHEUS_URL=

# The numeric "Username / Instance ID" shown on that page
GRAFANA_CLOUD_PROMETHEUS_USER=

# An API token generated on that page (Password) — grafana.com → My Account →
# Security → API Keys, scope "MetricsPublisher" also works
GRAFANA_CLOUD_API_KEY=
